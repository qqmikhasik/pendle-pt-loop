# Copy to `.env` and fill in your own keys.
# As of Session 4 NONE of these are strictly required — the Pendle REST,
# Morpho GraphQL, and Binance public REST loaders are all keyless. The
# keys below become useful in:
#
#   - Session 5/6 — if we add an on-chain leg (e.g. sUSDe pricePerShare
#                   via Alchemy RPC; sUSDe depeg verification).
#   - Session 6   — fallback to The Graph subgraph if Pendle REST or
#                   Morpho GraphQL becomes unreliable.
#   - Session 7   — Dune dashboards for the whitepaper.

ALCHEMY_URL=https://eth-mainnet.g.alchemy.com/v2/<your-alchemy-key>
ETHERSCAN_API_KEY=<your-etherscan-key>
THEGRAPH_API_KEY=<your-the-graph-gateway-key>
DUNE_API_KEY=<your-dune-key>
